# --- Database (Postgres) ---
# Used by Prisma (packages/db) and apps.
DATABASE_URL="postgresql://quatecalc:quatecalc@localhost:5432/quatecalc?schema=public"

# --- Redis (BullMQ queues + scrape page cache) ---
REDIS_URL="redis://localhost:6379"

# --- Scraper ---
# Polite User-Agent string sent with scrape requests (identify yourself + contact).
SCRAPER_USER_AGENT="QuateCalcBot/0.1 (+mailto:contact@example.com)"
# Minimum delay between requests to the same host, milliseconds.
SCRAPER_MIN_DELAY_MS="1500"
# Max concurrent requests per supplier host.
SCRAPER_CONCURRENCY="2"
# Respect robots.txt (true/false). Keep true unless you have explicit permission.
SCRAPER_RESPECT_ROBOTS="true"

# --- Pricing defaults ---
# Israeli VAT (מע"מ) percentage. 18% as of 2026; configurable per quote.
DEFAULT_VAT_PERCENT="18"

# --- Web app ---
NEXT_PUBLIC_DEFAULT_REGION="center"
